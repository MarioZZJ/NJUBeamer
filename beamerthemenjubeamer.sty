%%
%% beamerthemenjubeamer.sty
%% 南京大学 Beamer 主题
%%
%% 基于 CambridgeUS 主题 + dolphin 配色
%% 颜色来自南京大学视觉形象规范化标准
%%

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{beamerthemenjubeamer}[2026/03/22 v0.2.0 NJU Beamer Theme]

%% ============================
%% 基础主题
%% ============================

\usetheme{CambridgeUS}
\usecolortheme{dolphin}
\usefonttheme{professionalfonts}

%% ============================
%% 选项
%% ============================

% 语言选项：en 表示纯英文模式
\newif\ifnjubeamer@en\njubeamer@enfalse
\DeclareOptionBeamer{en}{\njubeamer@entrue}

% 节前目录
\newif\ifnjubeamer@sectiontoc\njubeamer@sectiontocfalse
\DeclareOptionBeamer{sectiontoc}{\njubeamer@sectiontoctrue}

% 节前过渡页（居中显示节标题，默认开启）
\newif\ifnjubeamer@sectionpage\njubeamer@sectionpagetrue
\DeclareOptionBeamer{nosectionpage}{\njubeamer@sectionpagefalse}

\ProcessOptionsBeamer

%% ============================
%% 中文支持
%% ============================

\ifnjubeamer@en\else
  \RequirePackage[fontset=none]{ctex}
  \setCJKmainfont{Songti SC}[BoldFont={Heiti SC}]
  \setCJKsansfont{Heiti SC}[BoldFont={Heiti SC Medium}]
  \setCJKmonofont{FZFangSong-Z02}
\fi

%% ============================
%% 南京大学标准色
%% ============================

% 标准色：C:50 M:100 Y:0 K:40
\definecolor{njuviolet}{cmyk}{0.50, 1, 0, 0.40}

% 辅助色
\definecolor{njumagenta}{cmyk}{0.05, 1, 0.55, 0}
\definecolor{njublue}{cmyk}{0.80, 0.50, 0, 0}
\definecolor{njuyellow}{cmyk}{0, 0.30, 1, 0}

%% ============================
%% 配色方案（三级渐变）
%% ============================

% palette primary: 最浅（顶栏/底栏两侧）
% palette secondary: 中间
% palette tertiary: 最深（标题栏等）
\setbeamercolor*{palette primary}{bg=njuviolet!30}
\setbeamercolor*{palette secondary}{bg=njuviolet!65, fg=white}
\setbeamercolor*{palette tertiary}{bg=njuviolet, fg=white}

% 标题
\setbeamercolor*{titlelike}{fg=njuviolet}
\setbeamercolor*{title}{bg=njuviolet, fg=white}

% 列表与标题
\setbeamercolor*{item}{fg=njuviolet}
\setbeamercolor*{caption name}{fg=njuviolet}
\setbeamercolor*{structure}{fg=njuviolet}

% Block
\setbeamercolor{block title}{fg=white, bg=njuviolet}
\setbeamercolor{block body}{bg=njuviolet!10}
\setbeamercolor{block title alerted}{fg=white, bg=njumagenta}
\setbeamercolor{block body alerted}{bg=njumagenta!10}
\setbeamercolor{block title example}{fg=white, bg=njublue}
\setbeamercolor{block body example}{bg=njublue!10}

%% ============================
%% 字体
%% ============================

\setbeamerfont{title}{size=\large}
\setbeamerfont{subtitle}{size=\small}
\setbeamerfont{author}{size=\small}
\setbeamerfont{date}{size=\small}
\setbeamerfont{institute}{size=\small}

%% ============================
%% 导航与杂项
%% ============================

\setbeamertemplate{navigation symbols}{}
\setbeamertemplate{caption}[numbered]
\setbeamertemplate{bibliography item}[text]

%% ============================
%% 节过渡页
%% ============================

\ifnjubeamer@sectionpage
  \AtBeginSection[]{
    \begin{frame}
      \vfill
      \centering
      \begin{beamercolorbox}[sep=8pt,center,shadow=true,rounded=true]{title}
        \usebeamerfont{title}\insertsectionhead\par%
      \end{beamercolorbox}
      \vfill
    \end{frame}
  }
\fi

\ifnjubeamer@sectiontoc
  \AtBeginSection[]{
    \begin{frame}
      \frametitle{目录}
      \tableofcontents[currentsection]
    \end{frame}
  }
\fi

\mode<all>
